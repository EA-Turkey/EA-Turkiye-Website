{{- partial "helpers/lang-context.html" . -}}
{{- $langSite := .Scratch.Get "langSite" -}}
{{- $searchConfig := site.Data.search | default dict -}}
{{- $items := slice -}}
{{- $landingSections := slice "about" "get-involved" "cause-areas" -}}
{{- $typeLabels := dict
  "about" (i18n "search_section_about")
  "blog" (i18n "search_section_blog")
  "cause-areas" (i18n "search_section_cause_areas")
  "events" (i18n "search_section_events")
  "get-involved" (i18n "search_section_get_involved")
  "news" (i18n "search_section_news")
  "page" (i18n "search_section_page")
-}}
{{- $modeLabels := dict
  "hybrid" (i18n "mode_hybrid")
  "in-person" (i18n "mode_in_person")
  "online" (i18n "mode_online")
-}}
{{- $levelLabels := dict
  "intermediate" (i18n "level_intermediate")
  "intro" (i18n "level_intro")
-}}
{{- $causeLabels := dict
  "ai-safety" (i18n "cause_ai_safety")
  "animal-welfare" (i18n "cause_animal_welfare")
  "biosecurity" (i18n "cause_biosecurity")
  "general" (i18n "cause_general")
  "global-health-poverty" (i18n "cause_global_health_poverty")
-}}
{{- $groupLabels := dict
  "about" (i18n "search_group_about")
  "blog" (i18n "search_group_blog")
  "cause-areas" (i18n "search_group_cause_areas")
  "events" (i18n "search_group_events")
  "get-involved" (i18n "search_group_get_involved")
  "news" (i18n "search_group_news")
  "page" (i18n "search_group_page")
-}}
{{- $sectionPriorities := dict
  "events" 96
  "cause-areas" 82
  "get-involved" 76
  "blog" 48
  "news" 42
  "about" 38
  "page" 24
-}}

{{- range $langSite.RegularPages -}}
  {{- $items = $items | append (partial "helpers/search-record.html" (dict
    "page" .
    "searchConfig" $searchConfig
    "typeLabels" $typeLabels
    "groupLabels" $groupLabels
    "modeLabels" $modeLabels
    "levelLabels" $levelLabels
    "causeLabels" $causeLabels
    "sectionPriorities" $sectionPriorities
  )) -}}
{{- end -}}

{{- range $langSite.Pages -}}
  {{- $sectionKey := partial "helpers/section-key.html" . | strings.TrimSpace -}}
  {{- if and .IsSection (in $landingSections $sectionKey) -}}
    {{- $items = $items | append (partial "helpers/search-record.html" (dict
      "page" .
      "searchConfig" $searchConfig
      "typeLabels" $typeLabels
      "groupLabels" $groupLabels
      "modeLabels" $modeLabels
      "levelLabels" $levelLabels
      "causeLabels" $causeLabels
      "sectionPriorities" $sectionPriorities
    )) -}}
  {{- end -}}
{{- end -}}

{{- jsonify (dict "indent" "  ") $items -}}
